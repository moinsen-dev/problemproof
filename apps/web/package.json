{
  "name": "problemproof-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "wrangler types",
    "dev": "astro dev",
    "prebuild": "wrangler types",
    "build": "astro check && astro build",
    "preview": "astro build && wrangler dev",
    "deploy": "astro build && wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "cf:typegen": "wrangler types",
    "db:migrate:local": "wrangler d1 migrations apply problemproof --local",
    "db:seed:local": "wrangler d1 execute problemproof --local --file ./seed.sql",
    "db:reset:local": "wrangler d1 migrations apply problemproof --local"
  },
  "dependencies": {
    "@astrojs/cloudflare": "14.1.4",
    "astro": "7.1.3"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@cloudflare/workers-types": "5.20260721.1",
    "@types/node": "26.1.1",
    "node-addon-api": "8.9.0",
    "node-gyp": "13.0.1",
    "typescript": "6.0.3",
    "vitest": "4.1.10",
    "wrangler": "4.112.0"
  }
}
