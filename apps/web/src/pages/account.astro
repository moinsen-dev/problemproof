---
import { env } from 'cloudflare:workers';
import SiteFooter from '../components/SiteFooter.astro';
import { authConfig, currentUser } from '../lib/auth';
import { validationLabel } from '../lib/problems';
import '../styles/global.css';

const user = await currentUser(Astro.request, env.DB, env);
const authReady = authConfig(env).enabled;
const loginUrl = `/auth/github?returnTo=${encodeURIComponent('/account/')}`;
const tokens = user ? await env.DB.prepare(`
  SELECT name, created_at, last_used_at, revoked_at
  FROM personal_tokens
  WHERE user_id = ?
  ORDER BY created_at DESC
  LIMIT 20
`).bind(user.id).all<{ name: string; created_at: string; last_used_at: string | null; revoked_at: string | null }>() : null;
const myProblems = user ? await env.DB.prepare(`
  SELECT
    p.id, p.slug, p.title, p.statement, p.target_group, p.region, p.category, p.proof_status, p.created_at,
    COUNT(DISTINCT c.id) AS confirmations_count,
    COUNT(DISTINCT e.id) AS incidents_count,
    (SELECT COUNT(*) FROM problem_events ev WHERE ev.problem_id = p.id AND ev.event_type = 'view') AS views_count,
    (SELECT COUNT(*) FROM problem_events ev WHERE ev.problem_id = p.id AND ev.event_type = 'share') AS shares_count,
    (SELECT COUNT(*) FROM proof_reactions pr WHERE pr.problem_id = p.id AND pr.reaction_type = 'not_my_problem') AS not_my_problem_count
  FROM problems p
  LEFT JOIN confirmations c ON c.problem_id = p.id
  LEFT JOIN evidence e ON e.problem_id = p.id
  WHERE p.user_id = ?
  GROUP BY p.id
  ORDER BY p.created_at DESC
  LIMIT 50
`).bind(user.id).all<{
  id: number;
  slug: string;
  title: string;
  statement: string;
  target_group: string;
  region: string;
  category: string;
  proof_status: 'needs-proof' | 'strong';
  created_at: string;
  confirmations_count: number;
  incidents_count: number;
  views_count: number;
  shares_count: number;
  not_my_problem_count: number;
}>() : null;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="theme-color" content="#ffffff" />
    <title>Account – ProblemProof</title>
  </head>
  <body>
    <header class="site-header legal-header">
      <a class="brand" href="/" aria-label="ProblemProof Startseite">
        <span class="brand-mark" aria-hidden="true"><i></i></span>
        <span>ProblemProof</span>
      </a>
      <a class="back-link" href="/">Zurück zum Feed</a>
    </header>

    <main class="legal-main account-main">
      <section class="legal-title">
        <p class="section-kicker">Account</p>
        <h1>Private Teilnahme</h1>
        <p>Favoriten, eigene Bestätigungen und Skill-Tokens hängen an deinem privaten ProblemProof-Account.</p>
      </section>

      {user ? (
        <section class="account-panel">
          <h2>{user.displayName}</h2>
          <p>Öffentlich erscheint keine Voterliste und kein GitHub-Profil. ProblemProof nutzt den Account, um doppelte Interaktionen zu verhindern.</p>

          <h2>Meine Probleme</h2>
          <div class="creator-problems">
            {(myProblems?.results ?? []).length ? myProblems?.results.map((problem) => (
              <article class="creator-problem">
                <div>
                  <span class="validation-pill">{validationLabel(problem)}</span>
                  <h3><a href={`/problems/${problem.slug}`}>{problem.title}</a></h3>
                  <p>{problem.statement}</p>
                  <small>{problem.target_group} · {problem.region} · {problem.category}</small>
                </div>
                <dl class="creator-metrics">
                  <div><dt>Views</dt><dd>{problem.views_count}</dd></div>
                  <div><dt>Shares</dt><dd>{problem.shares_count}</dd></div>
                  <div><dt>Bestätigt</dt><dd>{problem.confirmations_count}</dd></div>
                  <div><dt>Nein</dt><dd>{problem.not_my_problem_count}</dd></div>
                  <div><dt>Vorfälle</dt><dd>{problem.incidents_count}</dd></div>
                </dl>
              </article>
            )) : <p>Noch keine eigenen Probleme. Poste ein Problem aus dem Feed oder per Skill.</p>}
          </div>

          <form class="token-form" data-token-form>
            <label class="field">
              <span>Token-Name</span>
              <input name="name" maxlength="80" value="ProblemProof Skill" />
            </label>
            <button class="button primary" type="submit">Skill-Token erzeugen</button>
          </form>
          <div class="token-result" data-token-result hidden></div>

          <h2>Tokens</h2>
          <div class="token-list">
            {(tokens?.results ?? []).length ? tokens?.results.map((token) => (
              <article>
                <strong>{token.name}</strong>
                <span>Erstellt: {token.created_at}</span>
                <span>Zuletzt genutzt: {token.last_used_at ?? 'noch nie'}</span>
              </article>
            )) : <p>Noch keine Tokens.</p>}
          </div>
        </section>
      ) : (
        <section class="account-panel">
          <h2>Login erforderlich</h2>
          <p>{authReady ? 'Melde dich mit GitHub an, um Favoriten und Skill-Tokens zu nutzen.' : 'GitHub Login ist im Deployment noch nicht konfiguriert.'}</p>
          {authReady && <a class="button primary" href={loginUrl}>Mit GitHub anmelden</a>}
        </section>
      )}
    </main>

    <SiteFooter />
    <div class="toast" role="status" aria-live="polite"></div>
    <script src="../scripts/app.ts"></script>
  </body>
</html>
